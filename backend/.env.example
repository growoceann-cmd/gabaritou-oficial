# ─── Gabaritou v3 - Variáveis de Ambiente ─────────────────────────
# REQUIRED: Set these before running the application
# OPTIONAL: Uncomment and configure as needed

# ─── REQUIRED ─────────────────────────────────────────────────────

# Telegram Bot
BOT_TOKEN=SEU_BOT_TOKEN_AQUI

# Admin
ADMIN_SECRET=sua-admin-secret-aqui

# Banco de Dados PostgreSQL (Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/gabaritou

# Pagamentos (MercadoPago)
MP_ACCESS_TOKEN=SEU_ACCESS_TOKEN_MERCADOPAGO
MP_WEBHOOK_URL=https://seu-dominio.com/api/payments/webhook
MP_WEBHOOK_SECRET=COLE_O_WEBHOOK_SECRET_DO_MERCADOPAGO

# ─── OPTIONAL ─────────────────────────────────────────────────────

# Servidor
PORT=3000
NODE_ENV=production
CORS_ORIGIN=https://gabaritou.com.br

# JWT
JWT_SECRET=seu-jwt-secret-aqui
JWT_EXPIRES_IN=7d

# IA (OpenAI / Groq)
OPENAI_API_KEY=sk-sua-chave-openai
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Preços (R$) — Vigência: 2026
PRICE_LAUNCH=19.90
PRICE_REGULAR=24.90
LAUNCH_PERIOD_MONTHS=6
TRIAL_DAYS=7

# Data de lançamento
LAUNCH_DATE=2026-04-01

# Rate Limiting
RATE_LIMIT_PER_MINUTE=120

# B2B
# B2B_API_KEYS=

# Log
LOG_LEVEL=info
