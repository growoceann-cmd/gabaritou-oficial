# ============================================================
# Gabaritou v2 - Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no controle de versão!
# ============================================================

# --- Servidor ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# --- IA (Groq ou OpenAI) ---
# Use uma das duas opções abaixo:
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase (Banco de Dados) ---
SUPABASE_URL=https://xxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# --- Pagamentos (Mercado Pago) ---
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Autenticação ---
JWT_SECRET=sua-chave-secreta-jwt-muito-forte-aqui-minimo-32-chars
B2B_JWT_SECRET=sua-chave-secreta-b2b-jwt-aqui-minimo-32-chars

# --- Admin ---
ADMIN_SECRET=sua-chave-secreta-admin-aqui-minimo-16-chars

# --- API de Concursos ---
# (valor padrão, pode ser sobrescrito se necessário)
CONCURSOS_API_URL=https://concursos-api.deno.dev

# --- Frontend URL (para CORS) ---
FRONTEND_URL=http://localhost:5173

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Data Flywheel ---
FLYWHEEL_MIN_FEEDBACKS_FOR_PUBLISH=10

# --- B2B ---
B2B_BASIC_PRICE_PER_STUDENT=3
B2B_PRO_PRICE_PER_STUDENT=5
B2B_ENTERPRISE_PRICE_PER_STUDENT=8

# --- Webhook URLs (opcional) ---
# WEBHOOK_URL=https://seu-server.com/webhooks/gabaritou
